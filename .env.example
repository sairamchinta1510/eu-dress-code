# Microsoft Azure App Registration
REACT_APP_MSAL_CLIENT_ID=your-azure-client-id-here
REACT_APP_MSAL_TENANT_ID=your-azure-tenant-id-here
REACT_APP_MSAL_REDIRECT_URI=http://localhost:3000

# Google Gemini (Vercel server-side only — never commit the real key)
GEMINI_API_KEY=your-gemini-api-key-here

# Production API (points to Vercel-deployed serverless function)
REACT_APP_API_URL=https://eu-dress-code.vercel.app

# Vercel CORS (set this in Vercel dashboard env vars, not here)
# ALLOWED_ORIGIN=https://tadpoleindustries.com
